# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (get it from @userinfobot)
OWNER_ID=123456789

# BRAVE
BRAVE_API_KEY=BSAH-dddddddsadfasdfasdfasdf444

# Database URL (SQLite)
DATABASE_URL=sqlite:clavamea.db

# LLM API Configuration (DeepSeek compatible)
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
# Tiered models for cost optimization (optional)
# LLM_MODEL_PRO=deepseek-v4-pro   # Used on first turn (complex reasoning + tool selection)
# LLM_MODEL_FLASH=deepseek-v4-flash # Used on follow-up turns (cheaper, summarization)
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# OpenRouter (alternative to DeepSeek)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODELS=google/gemini-2.0-flash,openai/gpt-4o-mini,anthropic/claude-3-haiku-20240307
OPENROUTER_TIMEOUT=60

# Application Settings
MAX_CONVERSATION_LENGTH=20
LOG_LEVEL=info
LOCALES_DIR=./locales
# Comma-separated list of absolute paths allowed for the File Organizer skill
ALLOWED_ORGANIZE_PATHS=/tmp,/Volumes/ExternalDrive

# Disable all path sandbox restrictions (set to "true" to allow access to any path)
# DISABLE_PATH_SANDBOX=true

# WhatsApp Integration (optional — omit to disable)
# URL of the whatsapp-bridge service
# WHATSAPP_BRIDGE_URL=http://localhost:8082
# Port for the webhook server that receives messages from the bridge
# WHATSAPP_WEBHOOK_PORT=8081