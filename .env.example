# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (get it from @userinfobot)
OWNER_ID=123456789

# BRAVE
BRAVE_API_KEY=BSAH-dddddddsadfasdfasdfasdfasdf444

# Database URL (SQLite)
DATABASE_URL=sqlite:clavamea.db

# LLM Provider Selection (optional: auto, nvidia, openrouter, deepseek)
# If set to 'auto' (default), priority is: NVIDIA > DeepSeek > OpenRouter
LLM_PROVIDER=auto

# LLM API Configuration (DeepSeek compatible - Direct API)
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
# Tiered models for cost optimization (optional)
# LLM_MODEL_PRO=deepseek-v4-pro   # Used on first turn (complex reasoning + tool selection)
# LLM_MODEL_FLASH=deepseek-v4-flash # Used on follow-up turns (cheaper, summarization)
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# NVIDIA API Configuration (Free models via NVIDIA API Catalog)
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA models available for free:
# deepseek-ai/deepseek-v4-pro
# deepseek-ai/deepseek-v4-flash
# minimaxai/minimax-m2.5
# z-ai/glm-4.5-air:free
# openai/gpt-oss-120b:free
# tencent/hy3-preview:free
NVIDIA_MODEL_PRO=deepseek-ai/deepseek-v4-pro   # Used on first turn (complex reasoning + tool selection)
NVIDIA_MODEL_FLASH=deepseek-ai/deepseek-v4-flash # Used on follow-up turns (cheaper, summarization)
NVIDIA_MAX_TOKENS=4096
NVIDIA_TEMPERATURE=0.7

# OpenRouter (alternative to DeepSeek and NVIDIA)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,minimax/minimax-m2.5:free,z-ai/glm-4.5-air:free,openai/gpt-oss-120b:free,tencent/hy3-preview:free
OPENROUTER_TIMEOUT=30

# Application Settings
MAX_CONVERSATION_LENGTH=20
LOG_LEVEL=info
LOCALES_DIR=./locales
# Comma-separated list of absolute paths allowed for the File Organizer skill
ALLOWED_ORGANIZE_PATHS=/tmp,/Volumes/ExternalDrive

# Path to the directory where docker-compose.yml is located for self-update
SERVER_UPDATE_PATH=/opt/docker/clavamea

# Disable all path sandbox restrictions (set to "true" to allow access to any path)
# DISABLE_PATH_SANDBOX=true

# WhatsApp Integration (optional — omit to disable)
# URL of the whatsapp-bridge service
# WHATSAPP_BRIDGE_URL=http://localhost:8082
# Port for the webhook server that receives messages from the bridge
# WHATSAPP_WEBHOOK_PORT=8081