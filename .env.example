# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (get it from @userinfobot)
OWNER_ID=123456789

# BRAVE Search API (required for web_search tool)
# Get a free API key at https://brave.com/search/api/
BRAVE_API_KEY=BSAH-your_key_here

# Database URL (SQLite)
DATABASE_URL=sqlite:clavamea.db

# LLM Provider Selection (auto, nvidia, openrouter, deepseek)
# auto = tries NVIDIA first, then DeepSeek (if configured as fallback)
LLM_PROVIDER=auto

# ─── DeepSeek API (Direct) ─────────────────────────────────────────────
# Used as primary when LLM_PROVIDER=deepseek, or as fallback when LLM_PROVIDER=auto + NVIDIA fails
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat
# Optional tiered models for cost optimization:
# LLM_MODEL_PRO=deepseek-chat       # Used on first turn (complex reasoning + tool selection)
# LLM_MODEL_FLASH=deepseek-chat     # Used on follow-up turns (cheaper, summarization)
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ─── NVIDIA API (Free via NVIDIA API Catalog) ──────────────────────────
# Sign up at https://build.nvidia.com/ to get an API key
# Browse available models at https://build.nvidia.com/explore/discover
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here
# NVIDIA models (check the catalog for current availability):
#   deepseek-ai/deepseek-r1
#   deepseek-ai/deepseek-r1:free
#   meta/llama-3.1-8b-instruct
#   meta/llama-3.3-70b-instruct
#   mistralai/mistral-7b-instruct-v0.3
NVIDIA_MODEL_PRO=deepseek-ai/deepseek-r1:free   # Used on first turn (complex reasoning + tool selection)
NVIDIA_MODEL_FLASH=meta/llama-3.1-8b-instruct   # Used on follow-up turns (cheaper, summarization)
NVIDIA_MAX_TOKENS=4096
NVIDIA_TEMPERATURE=0.7

# ─── OpenRouter (Multi-model router) ───────────────────────────────────
# Sign up at https://openrouter.ai/ to get an API key
# OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Comma-separated list of models (first = primary, rest = fallbacks):
# OPENROUTER_MODELS=google/gemini-2.0-flash-001,openai/gpt-4o-mini
# OPENROUTER_TIMEOUT=30

# ─── Application Settings ──────────────────────────────────────────────
MAX_CONVERSATION_LENGTH=20
LOG_LEVEL=info
LOCALES_DIR=./locales

# Comma-separated list of absolute paths allowed for file operations
ALLOWED_ORGANIZE_PATHS=/tmp,/home/josenaves/Downloads

# Path to docker-compose.yml directory for self-update (UpdateServer tool)
# SERVER_UPDATE_PATH=/opt/docker/clavamea

# Memory storage directory (per-user SOUL.md, USER.md, MEMORY.md)
MEMORY_DIR=./memory

# GitHub Token (required for GitHub tools: read/update issues, create PRs)
# Generate at: https://github.com/settings/tokens (scope: repo)
# GITHUB_TOKEN=ghp_your_token_here

# Disable all path sandbox restrictions (set to "true" to allow access to any path)
# DISABLE_PATH_SANDBOX=true

# ─── WhatsApp Integration (optional) ───────────────────────────────────
# URL of the whatsapp-bridge service
# WHATSAPP_BRIDGE_URL=http://localhost:8082
# Port for the webhook server that receives messages from the bridge
# WHATSAPP_WEBHOOK_PORT=8081
