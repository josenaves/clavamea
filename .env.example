# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (get it from @userinfobot)
OWNER_ID=123456789

# BRAVE
BRAVE_API_KEY=BSAH-dddddddsadfasdfasdfasdf444

# Database URL (SQLite)
DATABASE_URL=sqlite:clavamea.db

# LLM API Configuration (DeepSeek compatible)
LLM_API_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Application Settings
MAX_CONVERSATION_LENGTH=20
LOG_LEVEL=info
LOCALES_DIR=./locales
# Comma-separated list of absolute paths allowed for the File Organizer skill
ALLOWED_ORGANIZE_PATHS=/tmp,/Volumes/ExternalDrive